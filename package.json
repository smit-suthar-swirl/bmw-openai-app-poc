{
  "name": "bmw-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "apps/web",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=apps/web",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
