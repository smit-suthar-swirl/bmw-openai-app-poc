# ─────────────────────────────────────────────────────────
# BMW AI Assistant — Environment Variables (Phase 2)
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL required for Phase 2) ──────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/bmw_ai

# ── Authentication ───────────────────────────────────────────────────────────
# IMPORTANT: Change this secret in production — use a random 64-char string
JWT_SECRET=bmw-ai-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Get your key from https://app.posthog.com
# Leave blank to disable PostHog (events will still be tracked in the DB)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_SERVER_NAME=bmw-ai-mcp
MCP_SERVER_VERSION=2.0.0
